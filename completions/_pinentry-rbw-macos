#compdef pinentry-rbw-macos
# Zsh completion for pinentry-rbw-macos
# Install: cp _pinentry-rbw-macos to a directory in $fpath, then run: compinit

_pinentry-rbw-macos() {
    local -a options
    options=(
        '--store[Prompt securely and save the master password to Keychain]'
        '--store-stdin[Read master password from stdin and save it to Keychain]'
        '--clear[Remove the stored master password from Keychain]'
        '--version[Show version information]'
        '--help[Show usage information]'
        '--ttyname=[Use PATH as the terminal device]:terminal device:_files'
        '--timeout=[Cancel input after SECONDS (0 disables timeout)]:seconds:'
        '--display=[Pass DISPLAY to the graphical prompt]:display:'
        '--no-global-grab[Do not request a global input grab]'
        '--lc-messages=[Select application messages]:locale:(en zh-Hans)'
    )
    _arguments -s $options
}

_pinentry-rbw-macos "$@"
